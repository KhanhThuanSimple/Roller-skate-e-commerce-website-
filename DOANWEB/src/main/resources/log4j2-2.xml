<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="DEBUG">
    <Appenders>
        <Console name="LogToConsole" target="SYSTEM_OUT">
            <PatternLayout pattern="[%5level] %d{dd-MM-yyyy HH:mm:ss} [%t] %c{1} - %msg%n" />
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="org.apache.logging.log4j" level="debug" additivity="false">
            <AppenderRef ref="LogToConsole"/>
        </Logger>
        <Logger name="vn.edu.hcmuaf.fit.doanweb" level="debug" additivity="false">
            <AppenderRef ref="LogToConsole"/>
        </Logger>
        <Root level="error">
            <AppenderRef ref="LogToConsole"/>
        </Root>
    </Loggers>
</Configuration>